# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=vpn
POSTGRES_PASSWORD=vpn_secret_change_me
POSTGRES_DB=vpn_platform
DATABASE_URL=postgresql+asyncpg://vpn:vpn_secret_change_me@postgres:5432/vpn_platform

# ============================================================
# Service-to-Service auth
# ============================================================
SERVICE_API_KEY=change-me-to-a-long-random-string

# ============================================================
# Service URLs (internal docker network)
# ============================================================
USER_SERVICE_URL=http://user-service:8000
BILLING_SERVICE_URL=http://billing-service:8000
VPN_SERVICE_URL=http://vpn-service:8000
API_GATEWAY_URL=http://api-gateway:8000

# ============================================================
# Telegram Bot
# ============================================================
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
BOT_MODE=polling
# WEBHOOK_URL=https://yourdomain.com/webhook

# ============================================================
# YooKassa
# ============================================================
